-- 사전검색 로직

local PAGE_SIZE   = 20          -- 한 번에 보여줄 개수
local allResults  = {}          -- 현재 검색 전체 결과
local shownCount  = 0           -- 현재 화면에 표시된 수

-- RichText 특수문자 이스케이프
local function escapeRich(s)
	s = s:gsub("&",  "&amp;")
	s = s:gsub("<",  "&lt;")
	s = s:gsub(">",  "&gt;")
	s = s:gsub('"',  "&quot;")
	return s
end

-- 결과 1행 생성 (query 부분을 파란 강조 표시)
local function makeResultRow(word, query, order)
	local row = Instance.new("TextLabel")
	row.Size = UDim2.new(1, 0, 0, 21)
	row.BackgroundColor3 = Color3.fromRGB(36, 36, 48)
	row.BorderSizePixel = 0
	row.RichText = true
	row.Font = Enum.Font.Code
	row.TextSize = 12
	row.TextColor3 = Color3.new(1, 1, 1)
	row.TextXAlignment = Enum.TextXAlignment.Left
	row.ZIndex = 4
	row.LayoutOrder = order
	row.Parent = resultsFrame
	Instance.new("UICorner", row)

	-- query 위치 찾아 파란 강조
	local qLen = #query
	local pos = word:find(query, 1, true)
	if pos then
		local pre  = escapeRich(word:sub(1, pos - 1))
		local mid  = escapeRich(word:sub(pos, pos + qLen - 1))
		local suf  = escapeRich(word:sub(pos + qLen))
		row.Text = "  " .. pre
			.. '<font color="rgb(100,180,255)"><b>' .. mid .. "</b></font>"
			.. suf
	else
		row.Text = "  " .. escapeRich(word)
	end

	return row
end

local function renderPage()
	local endIdx = math.min(shownCount + PAGE_SIZE, #allResults)
	for i = shownCount + 1, endIdx do
		makeResultRow(allResults[i].word, allResults[i].query, i)
	end
	shownCount = endIdx

	-- CanvasSize 갱신
	local contentH = resultsLayout.AbsoluteContentSize.Y + 6
	resultsFrame.CanvasSize = UDim2.new(0, 0, 0, contentH)

	-- 더보기 버튼 표시 여부
	moreBtnContainer.Visible = shownCount < #allResults
end

local function clearResults()
	for _, child in ipairs(resultsFrame:GetChildren()) do
		if child:IsA("TextLabel") then child:Destroy() end
	end
end

local function doSearch(query)
	clearResults()
	allResults = {}
	shownCount = 0

	query = query:match("^%s*(.-)%s*$")

	if query == "" then
		queryBadge.Visible = false
		searchCountLbl.Text = ""
		moreBtnContainer.Visible = false
		resultsFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
		return
	end

	-- 뱃지 크기를 쿼리 길이에 맞게 조정
	local badgeW = math.max(30, utf8.len(query) * 13 + 12)
	queryBadge.Size = UDim2.new(0, badgeW, 0, 20)
	queryBadgeText.Text = query
	queryBadge.Visible = true

	local qLen = #query
	local seen = {}

	-- 모든 단어 탐색: 앞 / 중간 / 끝 전부 포함
	for _, wordList in pairs(dictionary) do
		for _, word in ipairs(wordList) do
			if not seen[word] and #word >= qLen then
				local pos = word:find(query, 1, true)
				if pos then
					seen[word] = true
					-- 정렬 우선순위: 앞=1, 중간=2, 끝=3
					local priority
					if pos == 1 then
						priority = 1
					elseif pos + qLen - 1 == #word then
						priority = 3
					else
						priority = 2
					end
					table.insert(allResults, {
						word     = word,
						query    = query,
						priority = priority,
						len      = utf8.len(word)
					})
				end
			end
		end
	end

	-- 정렬: 앞 > 중간 > 끝, 같은 우선순위면 가나다순
	table.sort(allResults, function(a, b)
		if a.priority ~= b.priority then
			return a.priority < b.priority
		end
		return a.word < b.word
	end)

	if #allResults == 0 then
		searchCountLbl.Text = "결과 없음"
	else
		searchCountLbl.Text = "총 " .. #allResults .. "개"
	end

	renderPage()
end

