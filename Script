-- 초성 테이블

local CHO = {
	"ㄱ","ㄲ","ㄴ","ㄷ","ㄸ","ㄹ",
	"ㅁ","ㅂ","ㅃ","ㅅ","ㅆ","ㅇ",
	"ㅈ","ㅉ","ㅊ","ㅋ","ㅌ","ㅍ","ㅎ"
}

local function getCho(char)
	local code = utf8.codepoint(char)
	if code >= 44032 and code <= 55203 then
		local base = code - 44032
		local cho = math.floor(base / 588) + 1
		return CHO[cho]
	end
	return char
end


---

-- 스마트 두음법칙
-- 두음법칙 대상: 초성이 ㄴ(2) 또는 ㄹ(5) 인 글자만
-- → ㄴ·ㄹ·ㅇ 세 가지 초성으로 변형해 사전 탐색
-- ㅇ 초성은 변형 없이 그대로 사용

local DUUM_IDX      = {[2] = true, [5] = true}
local DUUM_VARIANTS = {2, 5, 11}

local function getChoIndex(char)
	local code = utf8.codepoint(char)
	if code >= 44032 and code <= 55203 then
		return math.floor((code - 44032) / 588)
	end
	return nil
end

local function replaceChoPart(char, newChoIdx)
	local code = utf8.codepoint(char)
	if code >= 44032 and code <= 55203 then
		local rest = (code - 44032) % 588
		return utf8.char(44032 + newChoIdx * 588 + rest)
	end
	return char
end

local function getDuumVariants(startChar)
	local choIdx = getChoIndex(startChar)
	if not choIdx or not DUUM_IDX[choIdx] then
		return {startChar}
	end
	local variants = {}
	local seen = {}
	for _, idx in ipairs(DUUM_VARIANTS) do
		local v = replaceChoPart(startChar, idx)
		if not seen[v] then
			seen[v] = true
			table.insert(variants, v)
		end
	end
	return variants
end


