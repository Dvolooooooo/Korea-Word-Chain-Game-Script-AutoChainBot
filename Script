-- 사전검색 로직

local allResults = {}       -- 현재 검색 전체 결과
local searchType = "ALL"    -- "ALL" | "ATTACK" | "LONG" | "NORMAL"

-- RichText 특수문자 이스케이프
local function escapeRich(s)
        s = s:gsub("&",  "&amp;")
        s = s:gsub("<",  "&lt;")
        s = s:gsub(">",  "&gt;")
        s = s:gsub('"',  "&quot;")
        return s
end

-- 결과 1행 생성
-- query 부분 파란 강조, 한방단어는 왼쪽에 빨간 점 표시
local function makeResultRow(entry, order)
        local word  = entry.word
        local query = entry.query
        local tp = entry.typePri   -- 1=필수공격, 2=공격, 3=방어, 4=일반

        local row = Instance.new("TextLabel")
        row.Size = UDim2.new(1, 0, 0, 21)
        row.BackgroundColor3 = Color3.fromRGB(36, 36, 48)
        row.BorderSizePixel = 0
        row.RichText = true
        row.Font = Enum.Font.Code
        row.TextSize = 12
        row.TextColor3 = Color3.new(1, 1, 1)
        row.TextXAlignment = Enum.TextXAlignment.Left
        row.ZIndex = 4
        row.LayoutOrder = order
        row.Parent = resultsFrame
        Instance.new("UICorner", row)

        -- 도트 색: 필수공격=빨강, 공격=주황, 방어=노랑, 일반=회색
        local dotColor = tp == 1 and "rgb(255,70,70)"
                or tp == 2 and "rgb(255,160,40)"
                or tp == 3 and "rgb(220,200,50)"
                or "rgb(70,70,85)"
        local dot = '<font color="' .. dotColor .. '">●</font> '

        -- query 위치 찾아 파란 강조
        local qLen = #query
        local pos = word:find(query, 1, true)
        local body
        if pos then
                local pre = escapeRich(word:sub(1, pos - 1))
                local mid = escapeRich(word:sub(pos, pos + qLen - 1))
                local suf = escapeRich(word:sub(pos + qLen))
                body = pre .. '<font color="rgb(100,180,255)"><b>' .. mid .. "</b></font>" .. suf
        else
                body = escapeRich(word)
        end

        row.Text = " " .. dot .. body
        return row
end

local function clearResults()
        for _, child in ipairs(resultsFrame:GetChildren()) do
                if child:IsA("TextLabel") or child:IsA("TextButton")
                        or child:IsA("Frame") then
                        child:Destroy()
                end
        end
end

local function updateCanvasSize()
        local contentH = resultsLayout.AbsoluteContentSize.Y + 6
        resultsFrame.CanvasSize = UDim2.new(0, 0, 0, contentH)
