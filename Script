-- 사전 미리보기 빌드 (한방 가나다순 / 긴단어 길이·가나다순)

local function firstChosung(word)
        local cp = utf8.codepoint(word, 1)
        if cp >= 0xAC00 and cp <= 0xD7A3 then
                return math.floor((cp - 0xAC00) / 588)
        end
        return -1
end

local prebuiltKill = {}
local prebuiltLong = {}
do
        local seen = {}
        for _, wl in pairs(dictionary) do
                for _, word in ipairs(wl) do
                        if not seen[word] then
                                seen[word] = true
                                local lc = lastChar(word)
                                local isKill = not hasWordStarting(lc)
                                local wLen = utf8.len(word)
                                local typePri = essentialSet[word] and 1
                                        or (attackSet[word] and 2
                                        or (defSet[word] and 3 or 4))
                                local entry = {
                                        word = word, query = "",
                                        isKill = isKill, len = wLen,
                                        typePri = typePri,
                                        cs = firstChosung(word),
                                }
                                if isKill then
                                        table.insert(prebuiltKill, entry)
                                end
                                if wLen >= 5 then
                                        table.insert(prebuiltLong, entry)
                                end
                        end
                end
        end
end
-- 한방: 가나다순 (초성 → 단어 바이트순)
table.sort(prebuiltKill, function(a, b)
        if a.cs ~= b.cs then return a.cs < b.cs end
        return a.word < b.word
end)
-- 긴단어: 길이 내림 → 가나다순
table.sort(prebuiltLong, function(a, b)
        if a.len ~= b.len then return a.len > b.len end
        if a.cs ~= b.cs then return a.cs < b.cs end
        return a.word < b.word
end)


