-- 사전검색 로직

local allResults = {}       -- 현재 검색 전체 결과
local searchType = "ALL"    -- "ALL" | "ATTACK" | "LONG" | "NORMAL"

-- RichText 특수문자 이스케이프
local function escapeRich(s)
        s = s:gsub("&",  "&amp;")
        s = s:gsub("<",  "&lt;")
        s = s:gsub(">",  "&gt;")
        s = s:gsub('"',  "&quot;")
        return s
end

-- 결과 1행 생성
-- query 부분 파란 강조, 한방단어는 왼쪽에 빨간 점 표시
local function makeResultRow(entry, order)
        local word  = entry.word
        local query = entry.query
        local isAtk = entry.isAttack

        local row = Instance.new("TextLabel")
        row.Size = UDim2.new(1, 0, 0, 21)
        row.BackgroundColor3 = Color3.fromRGB(36, 36, 48)
        row.BorderSizePixel = 0
        row.RichText = true
        row.Font = Enum.Font.Code
        row.TextSize = 12
        row.TextColor3 = Color3.new(1, 1, 1)
        row.TextXAlignment = Enum.TextXAlignment.Left
        row.ZIndex = 4
        row.LayoutOrder = order
        row.Parent = resultsFrame
        Instance.new("UICorner", row)

        -- 앞에 유형 도트: 한방=빨강, 노멀=회색
        local dot = isAtk
                and '<font color="rgb(255,90,90)">●</font> '
                or  '<font color="rgb(70,70,85)">●</font> '

        -- query 위치 찾아 파란 강조
        local qLen = #query
        local pos = word:find(query, 1, true)
        local body
        if pos then
                local pre = escapeRich(word:sub(1, pos - 1))
                local mid = escapeRich(word:sub(pos, pos + qLen - 1))
                local suf = escapeRich(word:sub(pos + qLen))
                body = pre .. '<font color="rgb(100,180,255)"><b>' .. mid .. "</b></font>" .. suf
        else
                body = escapeRich(word)
        end

        row.Text = " " .. dot .. body
        return row
end

local function clearResults()
        for _, child in ipairs(resultsFrame:GetChildren()) do
                if child:IsA("TextLabel") then child:Destroy() end
        end
end

-- 전체 결과를 한 번에 렌더 (페이지 없음, 스크롤로 전부 볼 수 있음)
local function renderAll()
        clearResults()
        for i, entry in ipairs(allResults) do
                makeResultRow(entry, i)
        end
        local contentH = resultsLayout.AbsoluteContentSize.Y + 6
        resultsFrame.CanvasSize = UDim2.new(0, 0, 0, contentH)
        resultsFrame.CanvasPosition = Vector2.new(0, 0)
end

local function doSearch(query)
        query = query:match("^%s*(.-)%s*$")

        if query == "" then
                allResults = {}
                queryBadge.Visible = false
                searchCountLbl.Text = ""
                clearResults()
                resultsFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
                return
        end

        -- 뱃지 크기를 쿼리 길이에 맞게 조정
        local badgeW = math.max(30, utf8.len(query) * 13 + 12)
        queryBadge.Size = UDim2.new(0, badgeW, 0, 20)
        queryBadgeText.Text = query
        queryBadge.Visible = true

        local qLen = #query
        local seen = {}
        local raw  = {}

        -- 모든 단어 탐색: 앞 / 중간 / 끝 전부 포함
        for _, wordList in pairs(dictionary) do
                for _, word in ipairs(wordList) do
                        if not seen[word] and #word >= qLen then
                                local pos = word:find(query, 1, true)
                                if pos then
                                        seen[word] = true
                                        local isAtk = attackSet[word] == true
                                        -- 위치 우선순위: 앞=1 중간=2 끝=3
                                        local posPri
                                        if pos == 1 then posPri = 1
                                        elseif pos + qLen - 1 == #word then posPri = 3
                                        else posPri = 2
                                        end
                                        -- 유형 우선순위: 한방=1, 긴단어(>=5글자)=2, 노멀=3
                                        local wLen = utf8.len(word)
                                        local typePri = isAtk and 1 or (wLen >= 5 and 2 or 3)
                                        table.insert(raw, {
                                                word      = word,
                                                query     = query,
                                                isAttack  = isAtk,
                                                len       = wLen,
                                                posPri    = posPri,
                                                typePri   = typePri,
                                        })
                                end
                        end
                end
        end

        -- 유형 필터 적용
        local filtered = {}
        for _, entry in ipairs(raw) do
                local ok = false
                if     searchType == "ALL"    then ok = true
                elseif searchType == "ATTACK" then ok = entry.isAttack
                elseif searchType == "LONG"   then ok = entry.len >= 5
                elseif searchType == "NORMAL" then ok = not entry.isAttack
                end
                if ok then table.insert(filtered, entry) end
        end

        -- 정렬
        -- 전체모드: 유형(한방→긴단어→노멀) → 앞/중/끝 → 길이내림 → 가나다
        -- 한방모드: 길이내림 → 가나다
        -- 긴단어모드: 길이내림 → 가나다
        -- 노멀모드: 앞/중/끝 → 가나다
        table.sort(filtered, function(a, b)
                if searchType == "ALL" then
                        if a.typePri ~= b.typePri then return a.typePri < b.typePri end
                        if a.posPri  ~= b.posPri  then return a.posPri  < b.posPri  end
                        if a.len     ~= b.len     then return a.len     > b.len     end
                        return a.word < b.word
                elseif searchType == "LONG" then
                        if a.len ~= b.len then return a.len > b.len end
                        return a.word < b.word
                elseif searchType == "ATTACK" then
                        if a.len ~= b.len then return a.len > b.len end
                        return a.word < b.word
                else -- NORMAL
                        if a.posPri ~= b.posPri then return a.posPri < b.posPri end
                        return a.word < b.word
                end
        end)

        allResults = filtered

        if #allResults == 0 then
                searchCountLbl.Text = "결과 없음"
        else
                searchCountLbl.Text = "총 " .. #allResults .. "개"
        end

        renderAll()
end

