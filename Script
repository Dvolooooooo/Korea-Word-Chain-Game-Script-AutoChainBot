-- 문자열 유틸

local function firstChar(str)
	for _, c in utf8.codes(str) do
		return utf8.char(c)
	end
end

local function lastChar(str)
	local last
	for _, c in utf8.codes(str) do
		last = utf8.char(c)
	end
	return last
end

local function validWord(w)
	return w
		and utf8.len(w)
		and utf8.len(w) >= 2
		and w:match("^[가-힣]+$")
end


