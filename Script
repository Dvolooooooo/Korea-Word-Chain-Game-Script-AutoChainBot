        updateCanvasSize()
end


-- 전체 결과 렌더 (스크롤로 전부 볼 수 있음)
local function renderAll()
        clearResults()
        renderRows(1, #allResults)
        resultsFrame.CanvasPosition = Vector2.new(0, 0)
end

local function doSearch(query)
        query = query:match("^%s*(.-)%s*$")

        if query == "" then
                queryBadge.Visible = false
                -- 한방/긴단어 탭은 검색어 없어도 미리보기 전체 표시
                if searchType == "ATTACK" and #prebuiltKill > 0 then
                        allResults = prebuiltKill
                        searchCountLbl.Text = "한방 " .. #prebuiltKill .. "개"
                        renderAll()
                        return
                elseif searchType == "LONG" and #prebuiltLong > 0 then
                        allResults = prebuiltLong
                        searchCountLbl.Text = "긴단어 " .. #prebuiltLong .. "개"
                        renderAll()
                        return
                end
                allResults = {}
                searchCountLbl.Text = ""
                clearResults()
                resultsFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
                return
        end

        -- 뱃지 크기를 쿼리 길이에 맞게 조정
        local badgeW = math.max(30, utf8.len(query) * 13 + 12)
        queryBadge.Size = UDim2.new(0, badgeW, 0, 20)
        queryBadgeText.Text = query
        queryBadge.Visible = true

        local qLen = #query
        local seen = {}
        local raw  = {}

        -- 모든 단어 탐색: 앞 / 중간 / 끝 전부 포함
        -- 한방모드는 전체 스캔, 나머지는 523개 제한
        local RAW_CAP = math.huge
        local rawFull = false
        for _, wordList in pairs(dictionary) do
                if rawFull then break end
                for _, word in ipairs(wordList) do
                        if not seen[word] and #word >= qLen then
                                local pos = word:find(query, 1, true)
                                if pos then
                                        seen[word] = true
                                        local isAtk = essentialSet[word] or attackSet[word] or false
                                        local posPri
                                        if pos == 1 then posPri = 1
                                        elseif pos + qLen - 1 == #word then posPri = 3
                                        else posPri = 2
                                        end
                                        local wLen = utf8.len(word)
                                        local typePri = essentialSet[word] and 1
                                                or (attackSet[word] and 2
                                                or (defSet[word] and 3 or 4))
                                        table.insert(raw, {
                                                word      = word,
                                                query     = query,
                                                isAttack  = isAtk,
                                                isKill    = not hasWordStarting(lastChar(word)),
                                                len       = wLen,
                                                posPri    = posPri,
                                                typePri   = typePri,
                                        })
                                        if #raw >= RAW_CAP then
                                                rawFull = true
                                                break
                                        end
                                end
                        end
                end
        end

        -- 유형 필터 적용
        local filtered = {}
        for _, entry in ipairs(raw) do
                local ok = false
                if     searchType == "ALL"    then ok = true
                elseif searchType == "ATTACK" then ok = entry.isKill        -- 즉사(한방)단어만
                elseif searchType == "LONG"   then ok = entry.len >= 5
                elseif searchType == "NORMAL" then ok = entry.typePri >= 3   -- 방어 + 일반
                end
                if ok then table.insert(filtered, entry) end
        end

        -- 정렬
        -- 전체모드: 유형(한방→긴단어→노멀) → 앞/중/끝 → 길이내림 → 가나다
        -- 한방모드: 길이내림 → 가나다
        -- 긴단어모드: 길이내림 → 가나다
        -- 노멀모드: 앞/중/끝 → 가나다
        table.sort(filtered, function(a, b)
                if searchType == "ALL" then
                        if a.typePri ~= b.typePri then return a.typePri < b.typePri end
                        if a.posPri  ~= b.posPri  then return a.posPri  < b.posPri  end
                        if a.len     ~= b.len     then return a.len     > b.len     end
                        return a.word < b.word
                elseif searchType == "LONG" then
                        if a.len ~= b.len then return a.len > b.len end
                        return a.word < b.word
                elseif searchType == "ATTACK" then
                        if a.typePri ~= b.typePri then return a.typePri < b.typePri end
                        if a.len ~= b.len then return a.len > b.len end
                        return a.word < b.word
                else -- NORMAL
                        if a.posPri ~= b.posPri then return a.posPri < b.posPri end
                        return a.word < b.word
                end
        end)

        allResults = filtered

        if #allResults == 0 then
                searchCountLbl.Text = "결과 없음"
        else
                searchCountLbl.Text = "총 " .. #allResults .. "개"
        end

        renderAll()
end

