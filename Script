-- 초성 테이블

local CHO = {
        "ㄱ","ㄲ","ㄴ","ㄷ","ㄸ","ㄹ",
        "ㅁ","ㅂ","ㅃ","ㅅ","ㅆ","ㅇ",
        "ㅈ","ㅉ","ㅊ","ㅋ","ㅌ","ㅍ","ㅎ"
}

local function getCho(char)
        local code = utf8.codepoint(char)
        if code >= 44032 and code <= 55203 then
                local base = code - 44032
                local cho = math.floor(base / 588) + 1
                return CHO[cho]
        end
        return char
end


---

-- 표준 두음법칙 + 신엘룰/구엘룰 확장 (초성+중성 조합 기반)
--
-- 중성 인덱스 (0-base):
--   ㅏ=0 ㅐ=1 ㅑ=2 ㅒ=3 ㅓ=4 ㅔ=5 ㅕ=6 ㅖ=7
--   ㅗ=8 ㅘ=9 ㅙ=10 ㅚ=11 ㅛ=12 ㅜ=13 ㅝ=14 ㅞ=15 ㅟ=16
--   ㅠ=17 ㅡ=18 ㅢ=19 ㅣ=20
--
-- [ㄴ 계열] 아래 중성일 때만 ㄴ→ㅇ 두음법칙 적용
--   ㅑ ㅒ ㅕ ㅖ ㅛ ㅠ ㅣ  (냐→야 녀→여 뇨→요 뉴→유 니→이 등)
-- [ㄹ 계열]
--   ㅑ ㅒ ㅕ ㅖ ㅛ ㅟ ㅠ ㅣ → ㄹ→ㅇ (랴→야 려→여 료→요 류→유 리→이 뤼→위 등)
--   나머지 모음              → ㄹ→ㄴ (라→나 래→내 로→노 루→누 르→느 등)
--
-- fallback 순서:
--   ㄴ계열: ㅇ 변형 → ㄴ 원본
--   ㄹ(ㅇ변환 모음): ㅇ → ㄴ → ㄹ  (윰→늄→륨 순서)
--   ㄹ(ㄴ변환 모음): ㄴ → ㄹ        (노→로 순서)

-- ㄴ→ㅇ, ㄹ→ㅇ 를 유발하는 중성 인덱스
local N_TO_O = {[2]=true,[3]=true,[6]=true,[7]=true,[12]=true,[17]=true,[20]=true}
-- ㄹ→ㅇ 를 유발하는 중성 인덱스 (N_TO_O + ㅟ(16))
local R_TO_O = {[2]=true,[3]=true,[4]=true,[6]=true,[7]=true,[12]=true,[16]=true,[17]=true,[20]=true}

local function getChoIndex(char)
        local code = utf8.codepoint(char)
        if code >= 44032 and code <= 55203 then
                return math.floor((code - 44032) / 588)
        end
        return nil
end

local function getJungIndex(char)
        local code = utf8.codepoint(char)
        if code >= 44032 and code <= 55203 then
                return math.floor(((code - 44032) % 588) / 28)
        end
        return nil
end

local function replaceChoPart(char, newChoIdx)
        local code = utf8.codepoint(char)
        if code >= 44032 and code <= 55203 then
                local rest = (code - 44032) % 588
                return utf8.char(44032 + newChoIdx * 588 + rest)
        end
        return char
end

-- 주어진 글자의 두음법칙 변형 목록을 fallback 순서로 반환
-- (첫 번째가 가장 우선, 마지막이 최후 fallback)
local function getDuumVariants(startChar)
        local choIdx  = getChoIndex(startChar)
        local jungIdx = getJungIndex(startChar)

        if not choIdx or not jungIdx then
                return {startChar}
        end

        local variants = {}
        local seen = {}

        local function add(cho)
                local v = replaceChoPart(startChar, cho)
                if not seen[v] then
                        seen[v] = true
                        table.insert(variants, v)
                end
        end

        if choIdx == 2 then -- ㄴ 계열
                if N_TO_O[jungIdx] then
                        -- 냐→야, 녀→여, 뇨→요, 뉴→유, 니→이 등
                        add(11) -- ㅇ 변형 우선
                        add(2)  -- ㄴ 원본 fallback
                else
                        add(2)  -- 두음법칙 해당 없음
                end

        elseif choIdx == 5 then -- ㄹ 계열
                if R_TO_O[jungIdx] then
                        -- 랴→야, 려→여, 럿→엇, 료→요, 류→유, 리→이, 뤼→위, 륨→윰 등
                        -- ㄴ변형 X: 표준 두음법칙은 ㄹ→ㅇ만 (넛·늄 등 생성 안 함)
                        add(11) -- ㅇ 변형 (유, 윰, 율 등)
                        add(5)  -- ㄹ 원본 fallback
                elseif jungIdx == 5 then
                        -- ㅔ(레→네 X): 두음법칙 미적용, ㄹ 원본만
                        add(5)
                else
                        -- 라→나, 래→내, 로→노, 루→누, 르→느, 뢰→뇌 등
                        add(2)  -- ㄴ 변형 우선
                        add(5)  -- ㄹ 원본 fallback
                end

        else
                add(choIdx) -- 두음법칙 해당 없음
        end

        return variants
end


