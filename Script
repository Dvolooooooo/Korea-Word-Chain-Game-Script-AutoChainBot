-- 제출

local function submitWord(word)
        status.Text = "입력중: " .. word
        typingEffect(word)
        task.wait(0.1)
        status.Text = "전송: " .. word
        ReplicatedStorage
                :WaitForChild("Remotes")
                :WaitForChild("SumbitWord")
                :FireServer(word)
        usedWords[word] = true
end


