-- 점수 사전 계산
--
-- killable[startChar] = 해당 글자로 시작하는 한방단어(상대 이을 수 없음)가 존재하는지
-- wordScore[word] :
--   1-kill  (즉사)  = 100000 + bonus  (상대 대응 0개)
--   2-kill  (강제킬)= 10000  + bonus  (상대 모든 끝글자에서 내가 킬 가능)
--   일반           = -min(enemyCount,200)*5 + bonus
-- attackBonus : 필수공격=500, 공격=200, 방어=50, 일반=0

local killable  = {}
local wordScore = {}

-- 1단계: 글자별 한방 가능 여부 선계산
for startChar, wordList in pairs(dictionary) do
        for _, word in ipairs(wordList) do
                if not hasWordStarting(lastChar(word)) then
                        killable[startChar] = true
                        break
                end
        end
end

local function attackBonus(word)
        if essentialSet[word] then return 500
        elseif attackSet[word]  then return 200
        elseif defSet[word]     then return 50
        else                         return 0
        end
end

-- 2단계: 단어별 점수 계산
for _, wordList in pairs(dictionary) do
        for _, word in ipairs(wordList) do
                if not wordScore[word] then
                        local lc    = lastChar(word)
                        local bonus = attackBonus(word)

                        -- 상대 후보 수 + 고유 끝글자 수집 (최대 20개까지만)
                        -- 20개 초과 시 어차피 2-kill 불가능 → 조기 종료로 성능 절약
                        local enemyCount  = 0
                        local opLastChars = {}
                        local seenLC      = {}
                        local tooMany     = false
                        for _, v in ipairs(getDuumVariants(lc)) do
                                if tooMany then break end
                                local opList = dictionary[v]
                                if opList then
                                        enemyCount = enemyCount + #opList
                                        for _, ow in ipairs(opList) do
                                                local olc = lastChar(ow)
                                                if not seenLC[olc] then
                                                        seenLC[olc] = true
                                                        table.insert(opLastChars, olc)
                                                        if #opLastChars >= 20 then
                                                                tooMany = true
                                                                break
                                                        end
                                                end
                                        end
                                end
                        end

                        local score
                        if enemyCount == 0 then
                                -- 1-kill: 즉사
                                score = 100000 + bonus
                        elseif tooMany then
                                -- 상대 선택지 너무 많음 → 2-kill 불가, 패널티만
                                score = -math.min(enemyCount, 200) * 5 + bonus
                        else
                                -- 2-kill 체크: 상대의 모든 고유 끝글자에서 내가 킬 가능?
                                local is2Kill = true
                                for _, olc in ipairs(opLastChars) do
                                        local canKill = false
                                        for _, ov in ipairs(getDuumVariants(olc)) do
                                                if killable[ov] then canKill = true; break end
                                        end
                                        if not canKill then is2Kill = false; break end
                                end
                                local cap = math.min(enemyCount, 200)
                                score = (is2Kill and 10000 or 0) - cap * 5 + bonus
                        end

                        wordScore[word] = score
                end
        end
end

