-- 데이터

local usedWords = {}
local recentWords = {}
local lastStartChar = nil

local function isUsed(word)
        return usedWords[word] == true
end

local function addRecent(word)
        table.insert(recentWords, 1, word)
        if #recentWords > 20 then
                table.remove(recentWords)
        end
end

local function wasRecent(word)
        for _, v in ipairs(recentWords) do
                if v == word then return true end
        end
        return false
end

local function shuffle(tbl)
        for i = #tbl, 2, -1 do
                local j = math.random(i)
                tbl[i], tbl[j] = tbl[j], tbl[i]
        end
end

local function pickOne(candidates)
        if #candidates <= 0 then return nil end
        shuffle(candidates)
        local top = {}
        for i = 1, math.min(5, #candidates) do
                table.insert(top, candidates[i])
        end
        return top[math.random(1, #top)]
end


---

-- 한방

-- 공통: 후보 수집 → 점수 내림차순 정렬 → 상위 N개 중 랜덤 픽
local function findByScore(startChar, filterFn, topN)
        topN = topN or 3
        local candidates = {}
        local seenW = {}

        local function tryList(list)
                if not list then return end
                for _, word in ipairs(list) do
                        if not seenW[word] and not isUsed(word) and not wasRecent(word) then
                                seenW[word] = true
                                if not filterFn or filterFn(word) then
                                        table.insert(candidates, word)
                                end
                        end
                end
        end

        -- 1순위: 게임이 제시한 정확한 글자로 시작하는 단어
        --        (두음법칙 미적용 게임에서 변형 단어를 제출하면 거부됨)
        tryList(dictionary[startChar])

        -- 2순위: 정확한 글자 후보가 없을 때만 두음법칙 변형 fallback
        if #candidates == 0 then
                for _, variant in ipairs(getDuumVariants(startChar)) do
                        if variant ~= startChar then
                                tryList(dictionary[variant])
                        end
                end
        end

        if #candidates == 0 then return nil end
        table.sort(candidates, function(a, b)
                return (wordScore[a] or 0) > (wordScore[b] or 0)
        end)
        local selected = candidates[math.random(1, math.min(topN, #candidates))]
        if selected then addRecent(selected) end
        return selected
end

local function findBestWord(startChar)
        -- 1-kill 단어만 대상 (score >= 100000)
        return findByScore(startChar, function(w)
                return (wordScore[w] or 0) >= 100000
        end, 3)
end


---

-- 노멀

local function findNormalWord(startChar)
        -- 루트 유도 모드: maxRoute 설정에 따라 깊이 탐색
        -- 1-kill(score>=100000)은 한방 모드 전용 → 노멀에서 제외

        -- 1단계: 2-kill (score 10000~99999)
        local best = findByScore(startChar, function(w)
                local s = wordScore[w] or 0
                return s >= 10000 and s < 100000
        end, 5)
        if best then return best end

        -- 2단계: 3-kill (score 5000~9999) — maxRoute >= 3 시
        if maxRoute >= 3 then
                local b3 = findByScore(startChar, function(w)
                        local s = wordScore[w] or 0
                        return s >= 5000 and s < 10000
                end, 5)
                if b3 then return b3 end
        end

        -- 3단계: 4-kill (score 2000~4999) — maxRoute >= 4 시
        if maxRoute >= 4 then
                local b4 = findByScore(startChar, function(w)
                        local s = wordScore[w] or 0
                        return s >= 2000 and s < 5000
                end, 5)
                if b4 then return b4 end
        end

        -- 4단계: 5-kill (score 1000~1999) — maxRoute >= 5 시
        if maxRoute >= 5 then
                local b5 = findByScore(startChar, function(w)
                        local s = wordScore[w] or 0
                        return s >= 1000 and s < 2000
                end, 5)
                if b5 then return b5 end
        end

        -- 최후 fallback: N-kill 없을 때 일반 최고점 단어
        return findByScore(startChar, function(w)
                return (wordScore[w] or 0) < 10000
        end, 3)
end


---

-- 긴단어

local function findLongestWord(startChar)
        -- 길이 우선, 동점이면 점수 높은 순
        -- 정확한 글자 우선, 없으면 두음법칙 변형 fallback
        local candidates = {}
        local seenW = {}

        local function tryList(list)
                if not list then return end
                for _, word in ipairs(list) do
                        if not seenW[word] and not isUsed(word) and not wasRecent(word) then
                                seenW[word] = true
                                table.insert(candidates, word)
                        end
                end
        end

        tryList(dictionary[startChar])
        if #candidates == 0 then
                for _, variant in ipairs(getDuumVariants(startChar)) do
                        if variant ~= startChar then
                                tryList(dictionary[variant])
                        end
                end
        end
        if #candidates == 0 then return nil end
        table.sort(candidates, function(a, b)
                local la, lb = utf8.len(a), utf8.len(b)
                if la ~= lb then return la > lb end
                return (wordScore[a] or 0) > (wordScore[b] or 0)
        end)
        local selected = candidates[math.random(1, math.min(5, #candidates))]
        if selected then addRecent(selected) end
        return selected
end


