-- 데이터

local usedWords = {}
local recentWords = {}
local lastStartChar = nil

local function isUsed(word)
	return usedWords[word] == true
end

local function addRecent(word)
	table.insert(recentWords, 1, word)
	if #recentWords > 20 then
		table.remove(recentWords)
	end
end

local function wasRecent(word)
	for _, v in ipairs(recentWords) do
		if v == word then return true end
	end
	return false
end

local function hasWordStarting(char)
	for _, v in ipairs(getDuumVariants(char)) do
		if dictionary[v] then return true end
	end
	return false
end

local function shuffle(tbl)
	for i = #tbl, 2, -1 do
		local j = math.random(i)
		tbl[i], tbl[j] = tbl[j], tbl[i]
	end
end

local function pickOne(candidates)
	if #candidates <= 0 then return nil end
	shuffle(candidates)
	local top = {}
	for i = 1, math.min(5, #candidates) do
		table.insert(top, candidates[i])
	end
	return top[math.random(1, #top)]
end


---

-- 한방

local function findBestWord(startChar)
	local candidates = {}
	for _, variant in ipairs(getDuumVariants(startChar)) do
		local list = dictionary[variant]
		if list then
			for _, word in ipairs(list) do
				local last = lastChar(word)
				if not hasWordStarting(last)
					and not isUsed(word)
					and not wasRecent(word) then
					table.insert(candidates, word)
				end
			end
		end
	end
	local selected = pickOne(candidates)
	if selected then addRecent(selected) end
	return selected
end


---

-- 노멀

local function findNormalWord(startChar)
	local attackCandidates = {}
	local normalCandidates = {}
	for _, variant in ipairs(getDuumVariants(startChar)) do
		local alist = attackDictionary[variant]
		if alist then
			for _, word in ipairs(alist) do
				if not isUsed(word) and not wasRecent(word) then
					table.insert(attackCandidates, word)
				end
			end
		end
		local dlist = dictionary[variant]
		if dlist then
			for _, word in ipairs(dlist) do
				if not isUsed(word) and not wasRecent(word) then
					table.insert(normalCandidates, word)
				end
			end
		end
	end
	local pool = (#attackCandidates > 0) and attackCandidates or normalCandidates
	local selected = pickOne(pool)
	if selected then addRecent(selected) end
	return selected
end


---

-- 긴단어

local function findLongestWord(startChar)
	local ranked = {}
	for _, variant in ipairs(getDuumVariants(startChar)) do
		local list = dictionary[variant]
		if list then
			for _, word in ipairs(list) do
				if not isUsed(word) and not wasRecent(word) then
					table.insert(ranked, {word = word, len = utf8.len(word)})
				end
			end
		end
	end
	table.sort(ranked, function(a, b) return a.len > b.len end)
	local candidates = {}
	for i = 1, math.min(5, #ranked) do
		table.insert(candidates, ranked[i].word)
	end
	local selected = pickOne(candidates)
	if selected then addRecent(selected) end
	return selected
end


---

-- 생성

local function generateWord(startChar)
	if mode == "ONE" then
		return findBestWord(startChar)
	elseif mode == "LONG" then
		return findLongestWord(startChar)
	else
		return findNormalWord(startChar)
	end
end


---

-- 타이핑

local function typingEffect(word)
	local current = ""
	for _, code in utf8.codes(word) do
		local char = utf8.char(code)
		if inputMode == "MOBILE" then
			ReplicatedStorage
				:WaitForChild("Remotes")
				:WaitForChild("TypingWord")
				:FireServer(current .. getCho(char))
			task.wait(
				math.random(
					currentSpeed.Delay[1] * 1000,
					currentSpeed.Delay[2] * 1000
				) / 1000
			)
		end
		current = current .. char
		ReplicatedStorage
			:WaitForChild("Remotes")
			:WaitForChild("TypingWord")
			:FireServer(current)
		task.wait(
			math.random(
				currentSpeed.Delay[1] * 1000,
				currentSpeed.Delay[2] * 1000
			) / 1000
		)
	end
end


---

-- 제출

local function submitWord(word)
	status.Text = "입력중: " .. word
	typingEffect(word)
	task.wait(0.1)
	status.Text = "전송: " .. word
	ReplicatedStorage
		:WaitForChild("Remotes")
		:WaitForChild("SumbitWord")
		:FireServer(word)
	usedWords[word] = true
end


